<%- include('partials/header') %>

<div class="cozy-gradient rounded-3xl p-12 mb-12 text-center relative overflow-hidden">
  <h1 class="text-5xl font-bold mb-4 text-white">İsti Bir Film Gecəsi</h1>
  <p class="text-xl text-stone-400 max-w-lg mx-auto mb-8">Axtardığın filmi tap, yadda saxla və rəy bildir.</p>
  
  <form action="/search" method="GET" class="max-w-2xl mx-auto relative">
    <input type="text" name="q" placeholder="Film axtar..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
           class="w-full bg-stone-900 border border-stone-700 focus:border-amber-500 rounded-2xl px-6 py-4 text-lg outline-none transition-all shadow-inner text-white">
    <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 bg-amber-600 hover:bg-amber-700 px-6 py-2 rounded-xl font-medium transition-all text-white">
      Axtar
    </button>
  </form>
</div>

<h2 class="text-2xl font-semibold mb-6 flex items-center gap-3 text-white">
  <i class="fa-solid fa-compass text-amber-500"></i>
  <%= typeof searchQuery !== 'undefined' ? 'Axtarış Nəticələri' : 'Kəşf Et' %>
</h2>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
  <% if(movies && movies.length > 0) { %>
    <% movies.forEach(movie => { %>
      <a href="/movie/<%= movie.id %>" class="card block bg-stone-900 rounded-2xl overflow-hidden transition-all border border-stone-800/50">
        <img src="<%= movie.poster_url %>" class="w-full h-72 object-cover bg-stone-800" alt="<%= movie.title %>">
        <div class="p-4">
          <h3 class="font-medium text-stone-200 truncate"><%= movie.title %></h3>
          <p class="text-sm text-stone-500 mt-1"><%= movie.year || 'N/A' %></p>
        </div>
      </a>
    <% }) %>
  <% } else { %>
    <p class="col-span-full text-stone-500 text-center py-10">Film tapılmadı.</p>
  <% } %>
</div>

<%- include('partials/footer') %>