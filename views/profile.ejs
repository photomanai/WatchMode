<%- include('partials/header') %>

<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
  <div class="md:col-span-1">
    <div class="bg-stone-900 rounded-3xl p-6 border border-stone-800 mb-6 text-center">
      <div class="w-24 h-24 mx-auto bg-gradient-to-tr from-amber-500 to-orange-600 rounded-full flex items-center justify-center text-3xl font-bold text-white shadow-lg mb-4">
        <%= user.username.charAt(0).toUpperCase() %>
      </div>
      <h2 class="text-xl font-bold text-white"><%= user.username %></h2>
      <p class="text-stone-500 text-sm">Qeydiyyatlı İstifadəçi</p>
    </div>

    <div class="bg-stone-900 rounded-3xl p-6 border border-stone-800">
      <h3 class="font-semibold text-white mb-4">Dost Tap</h3>
      <form action="/profile/add-friend" method="POST" class="flex gap-2 mb-6">
        <input type="text" name="friend_username" placeholder="İstifadəçi Adı" class="w-full bg-stone-950 border border-stone-700 rounded-xl px-4 py-2 text-sm outline-none focus:border-amber-500">
        <button type="submit" class="bg-stone-800 hover:bg-stone-700 px-3 rounded-xl text-stone-300"><i class="fa-solid fa-user-plus"></i></button>
      </form>

      <h3 class="font-semibold text-white mb-3 border-b border-stone-800 pb-2">Dostlarım</h3>
      <ul class="space-y-3">
        <% if(friends.length > 0) { %>
          <% friends.forEach(friend => { %>
            <li class="flex items-center gap-3 text-stone-300">
              <i class="fa-solid fa-circle-user text-stone-600 text-lg"></i>
              <%= friend.username %>
            </li>
          <% }) %>
        <% } else { %>
          <p class="text-sm text-stone-500">Hələ heç bir dost əlavə etməmisən.</p>
        <% } %>
      </ul>
    </div>
  </div>

  <div class="md:col-span-3 bg-stone-900/50 rounded-3xl p-8 border border-stone-800">
    <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
      <i class="fa-solid fa-bookmark text-amber-500"></i> Yadda Saxladığım Filmlər
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      <% if(savedMovies.length > 0) { %>
        <% savedMovies.forEach(movie => { %>
          <a href="/movie/<%= movie.id %>" class="group relative rounded-xl overflow-hidden border border-stone-700">
            <img src="<%= movie.poster_url %>" class="w-full h-64 object-cover transition-transform group-hover:scale-105" alt="">
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-stone-950 p-4">
              <h3 class="font-medium text-white truncate"><%= movie.title %></h3>
            </div>
          </a>
        <% }) %>
      <% } else { %>
        <p class="col-span-full text-stone-500">Siyahında hələ film yoxdur.</p>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>