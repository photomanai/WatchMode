<%- include('partials/header') %>

<div class="max-w-md mx-auto mt-16 bg-stone-900 border border-stone-800 rounded-3xl p-8 shadow-2xl">
  <div class="text-center mb-8">
    <h2 class="text-3xl font-bold text-white mb-2">Qeydiyyatdan Keç</h2>
    <p class="text-stone-400">Watchmode-a qoşul və öz film kitabxananı yarat.</p>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-900/20 border border-red-500/50 text-red-400 px-4 py-3 rounded-xl mb-6 text-sm text-center">
      <%= error %>
    </div>
  <% } %>

  <form action="/register" method="POST" class="space-y-5">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div>
      <label class="block text-stone-400 text-sm font-medium mb-2" for="username">İstifadəçi Adı</label>
      <input type="text" id="username" name="username" required placeholder="Səhnədə istifadə edəcəyin ad"
             class="w-full bg-stone-950 border border-stone-700 rounded-xl px-4 py-3 text-white outline-none focus:border-amber-500 transition-colors shadow-inner">
    </div>

    <div>
      <label class="block text-stone-400 text-sm font-medium mb-2" for="email">E-poçt</label>
      <input type="email" id="email" name="email" required placeholder="nümunə@mail.com"
             class="w-full bg-stone-950 border border-stone-700 rounded-xl px-4 py-3 text-white outline-none focus:border-amber-500 transition-colors shadow-inner">
    </div>

    <div>
      <label class="block text-stone-400 text-sm font-medium mb-2" for="password">Şifrə</label>
      <input type="password" id="password" name="password" required placeholder="••••••••"
             class="w-full bg-stone-950 border border-stone-700 rounded-xl px-4 py-3 text-white outline-none focus:border-amber-500 transition-colors shadow-inner">
    </div>

    <button type="submit" class="w-full bg-amber-600 hover:bg-amber-700 text-white font-medium py-3 rounded-xl transition-colors mt-4 shadow-lg shadow-amber-900/20">
      Qeydiyyatdan Keç
    </button>
  </form>

  <p class="text-center text-stone-500 mt-8 text-sm">
    Artıq hesabın var? <a href="/login" class="text-amber-500 hover:text-amber-400 font-medium transition-colors">Daxil Ol</a>
  </p>
</div>

<%- include('partials/footer') %>